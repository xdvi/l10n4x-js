{
  "name": "@l10n4x/runtime",
  "version": "0.2.0",
  "description": "Isomorphic l10n4x runtime: loaders, init, translate",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external @l10n4x/wasm --external l10n4x-wasm",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@l10n4x/wasm": "workspace:*"
  },
  "peerDependencies": {
    "l10n4x-wasm": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "l10n4x-wasm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xdvi/l10n4x-js.git",
    "directory": "packages/runtime"
  }
}